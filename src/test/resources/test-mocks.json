[
  {
    "name": "Regular mock",
    "path": "/api/users",
    "method": "GET",
    "priority": 1,
    "response": {
      "status": 200,
      "json": {
        "message": "Hello world"
      }
    }
  },
  {
    "name": "Lower priority",
    "path": "/api/priority",
    "method": "GET",
    "priority": 1,
    "response": {
      "status": 200,
      "json": {
        "message": "Low priority"
      }
    }
  },
  {
    "name": "Higher priority",
    "path": "/api/priority",
    "method": "GET",
    "priority": 10,
    "response": {
      "status": 200,
      "json": {
        "message": "High priority"
      }
    }
  },
  {
    "name": "Template mock",
    "path": "/api/template/.*",
    "method": "POST",
    "priority": 1,
    "variables": {
      "var1": "value1"
    },
    "response": {
      "status": 201,
      "json": {
        "hello": "{{body.name}}",
        "var": "{{variables.var1}}",
        "param1": "{{request.myParam}}"
      }
    }
  },
  {
    "name": "Validation WARN",
    "path": "/api/validated/warn",
    "method": "POST",
    "validation": {
      "openApiSpec": "src/test/resources/test-openapi.yaml",
      "action": "WARN"
    },
    "response": {
      "status": 200,
      "json": {"result": "success"}
    }
  },
  {
    "name": "Validation FAIL",
    "path": "/api/validated/fail",
    "method": "POST",
    "validation": {
      "openApiSpec": "src/test/resources/test-openapi.yaml",
      "action": "FAIL"
    },
    "response": {
      "status": 200,
      "json": {"result": "success"}
    }
  },
  {
    "name": "Validation CUSTOM_ERROR",
    "path": "/api/validated/custom",
    "method": "POST",
    "validation": {
      "openApiSpec": "src/test/resources/test-openapi.yaml",
      "action": "CUSTOM_ERROR",
      "customErrorResponse": {
        "status": 400,
        "json": {"my_error": "failed_validation"}
      }
    },
    "response": {
      "status": 200,
      "json": {"result": "success"}
    }
  }
]
